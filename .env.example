# Supabase project URL — Settings > API in the Supabase dashboard.
# Safe to expose to the browser (NEXT_PUBLIC_*), but nothing in this app
# actually reads it client-side today — both lead-capture forms call our
# own API routes, which are the only thing that talks to Supabase.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only key with full database access, bypassing Row Level Security.
# Used exclusively inside app/api/inner-circle/apply and
# app/api/newsletter/subscribe (see lib/supabase.ts) — never sent to the
# browser. Do not prefix this with NEXT_PUBLIC_ under any circumstances.
SUPABASE_SERVICE_ROLE_KEY=

# Password for the founder-only /sanctum dashboard (see lib/sanctum/auth.ts).
# Server-only — never prefix with NEXT_PUBLIC_. Choose a long, random value.
ADMIN_PASSWORD=

# Resend API key — used only to send a best-effort admin notification email
# when a new Inner Circle application is submitted (see lib/email.ts and
# app/api/inner-circle/apply/route.ts). A failed or missing key never blocks
# an application from being saved; it only skips the notification.
# The "from" address in lib/email.ts must belong to a domain verified in
# your Resend dashboard, or every send will fail (silently, from the
# applicant's perspective — check server logs for "INNER CIRCLE EMAIL ERROR").
RESEND_API_KEY=

# Inbox that receives the "New Inner Circle Application" notification email.
ADMIN_NOTIFICATION_EMAIL=
